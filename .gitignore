# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
# Production build config — PUBLIC client values only (safe in the browser).
!.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# large media — the briefing video is >100MB (GitHub's limit). Host it externally
# for production (Supabase Storage / Vimeo / CDN) and point brief.videoSrc at it.
/public/*.mp4
