# Operation Getaway — environment.
# Copy to .env.local and fill in. Without these, the app runs on a local
# cross-tab mock realtime backend (no live cross-device sync).

# Supabase (realtime wheel state). Project Settings → API.
# The anon key is safe in the browser; NEVER put the service_role key here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Auth backend. "mock" (default) = pick-your-name. "google" is a Phase 2 swap
# and not implemented yet.
NEXT_PUBLIC_AUTH_MODE=mock

# Activity 2 commit leaderboard. A GitHub token (read-only on the teams' repos)
# used SERVER-SIDE only by /api/commits — never exposed to the browser. Optional
# for public repos (falls back to unauthenticated, 60 req/hr); required for
# private repos. The team→repo map lives in config/activity2.json.
GITHUB_TOKEN=
